# Root convenience reference. Copy values into app-specific .env files.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fisholha_miniapp?schema=public

API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000

WOOCOMMERCE_BASE_URL=https://fisholha.ru
WOOCOMMERCE_CONSUMER_KEY=ck_replace_me
WOOCOMMERCE_CONSUMER_SECRET=cs_replace_me

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_ENABLE_POLLING=false
TELEGRAM_BOT_USERNAME=replace_me
TELEGRAM_MINI_APP_URL=https://staging.fisholha.ru
TELEGRAM_DEV_MODE=true
TELEGRAM_DEV_USER_ID=100000000
TELEGRAM_DEV_USERNAME=dev_buyer
TELEGRAM_DEV_FIRST_NAME=Dev
TELEGRAM_DEV_LAST_NAME=Buyer
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
TELEGRAM_SESSION_TTL_SECONDS=2592000
ADMIN_TELEGRAM_IDS=100000001

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_TELEGRAM_DEV_MODE=true
NEXT_PUBLIC_MINI_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEV_USER_ROLE=buyer
NEXT_PUBLIC_REQUIRE_TELEGRAM_RUNTIME=false
