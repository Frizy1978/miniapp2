generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  admin
}

enum BatchStatus {
  draft
  open
  closed
  archived
}

enum OrderStatus {
  created
  accepted
}

enum ProductUnitType {
  piece
  weight
  other
}

enum SyncProvider {
  woocommerce
}

enum SyncType {
  categories
  products
  full_catalog
}

enum SyncRunStatus {
  running
  success
  failed
}

model User {
  id               String            @id @default(cuid())
  role             UserRole          @default(buyer)
  displayName      String
  username         String?
  firstName        String?
  lastName         String?
  locality         String?
  deliveryNote     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  telegramIdentity TelegramIdentity?
  orders           Order[]
  createdBatches   OrderBatch[]
  auditLogs        AdminAuditLog[]
}

model TelegramIdentity {
  id             String   @id @default(cuid())
  userId         String   @unique
  telegramUserId String   @unique
  username       String?
  firstName      String?
  lastName       String?
  lastAuthAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrderBatch {
  id              String      @id @default(cuid())
  code            String      @unique
  year            Int
  sequence        Int
  status          BatchStatus @default(draft)
  startsAt        DateTime?
  closesAt        DateTime?
  deliveryAt      DateTime?
  customerMessage String?
  createdById     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  createdBy       User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  orders          Order[]

  @@unique([year, sequence])
  @@index([status])
}

model Order {
  id          String      @id @default(cuid())
  code        String      @unique
  batchId     String
  buyerId     String
  status      OrderStatus @default(created)
  subtotal    Decimal     @db.Decimal(12, 2)
  comment     String?
  confirmedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  batch       OrderBatch  @relation(fields: [batchId], references: [id], onDelete: Restrict)
  buyer       User        @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  items       OrderItem[]

  @@unique([batchId, buyerId])
  @@index([status])
}

model OrderItem {
  id                  String          @id @default(cuid())
  orderId             String
  productId           String?
  productNameSnapshot String
  productSlugSnapshot String?
  skuSnapshot         String?
  unitTypeSnapshot    ProductUnitType @default(other)
  unitLabelSnapshot   String?
  priceSnapshot       Decimal         @db.Decimal(12, 2)
  quantity            Decimal         @db.Decimal(12, 3)
  lineTotal           Decimal         @db.Decimal(12, 2)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             ProductCache?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId])
}

model ProductCache {
  id         String          @id @default(cuid())
  externalId String          @unique
  slug       String          @unique
  sku        String?
  name       String
  imageUrl   String?
  price      Decimal         @db.Decimal(12, 2)
  currency   String          @default("RUB")
  unitType   ProductUnitType @default(other)
  unitLabel  String?
  isFeatured Boolean         @default(false)
  isNew      Boolean         @default(false)
  isActive   Boolean         @default(true)
  rawMeta    Json?
  syncedAt   DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  categories CategoryCache[]
  orderItems OrderItem[]

  @@index([isActive])
  @@index([name])
}

model CategoryCache {
  id         String          @id @default(cuid())
  externalId String          @unique
  slug       String          @unique
  name       String
  imageUrl   String?
  parentId   String?
  isActive   Boolean         @default(true)
  syncedAt   DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  parent     CategoryCache?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   CategoryCache[] @relation("CategoryTree")
  products   ProductCache[]

  @@index([isActive])
}

model SyncRun {
  id        String        @id @default(cuid())
  provider  SyncProvider
  syncType  SyncType
  status    SyncRunStatus @default(running)
  startedAt DateTime      @default(now())
  finishedAt DateTime?
  statsJson Json?
  errorText String?
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String
  payloadJson Json?
  createdAt   DateTime @default(now())
  adminUser   User     @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@index([entityType, entityId])
}
